# Convex deployment (auto-managed by `bunx convex dev`).
CONVEX_DEPLOYMENT=dev:your-deployment-slug
CONVEX_URL=https://your-slug.convex.cloud
CONVEX_SITE_URL=https://your-slug.convex.site

# Set in Convex dashboard → Settings → Environment variables (NOT here).
# `.env.local` in this folder is for `bunx convex dev` only — server-side
# secrets must be set via the dashboard so they're available at runtime.
#
# Required:
#   BETTER_AUTH_SECRET     openssl rand -base64 32
#   SITE_URL               http://localhost:3000  (dev)  |  https://app.echolive.dev (prod)
#
# Google OAuth (required for "Sign in with Google"):
#   GOOGLE_CLIENT_ID       from Google Cloud Console
#   GOOGLE_CLIENT_SECRET   ditto
#   Authorized redirect URI to register at Google:
#     https://<your-slug>.convex.site/api/auth/callback/google
#
# Resend (required for password reset + email verification):
#   RESEND_API_KEY         from resend.com dashboard
#   EMAIL_FROM             "Echo Live <noreply@your-verified-domain>"
#
# Desktop deep link (default `echolive`):
#   DESKTOP_REDIRECT_SCHEME  echolive
