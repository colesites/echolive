# Copy to .env.local for dev.

# Convex deployment URLs (from packages/backend/.env.local).
NEXT_PUBLIC_CONVEX_URL=https://bold-raccoon-845.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://bold-raccoon-845.convex.site

# Where the desktop app deep-link hands the token back. Override to a
# different scheme in prod if you ship a different app id.
NEXT_PUBLIC_DESKTOP_REDIRECT=echolive://auth/callback
