# Committed defaults for `tauri build` (production bundle).
# Override locally with `.env.production.local` if needed for a staging build.
#
# These are deliberately NOT in `.env.local` — that file is loaded in
# every Vite mode, so dev-only ngrok URLs there would leak into prod.

VITE_CONVEX_URL=https://bold-raccoon-845.convex.cloud
VITE_CONVEX_SITE_URL=https://bold-raccoon-845.convex.site

# Streaming destinations for shipped builds. RTMP host will move to your
# Hetzner ingest once that's provisioned; for now publishes only work
# from a machine that can reach a public MediaMTX.
VITE_RTMP_HOST=rtmp://localhost:1935
VITE_HLS_HOST=https://echolive-gha.vercel.app/hls
VITE_WEB_HOST=https://echolive-gha.vercel.app
VITE_AUTH_HOST=https://echolive-gha.vercel.app
