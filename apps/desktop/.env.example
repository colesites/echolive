# Copy to .env.local. Vite exposes VITE_* vars to the client.

# Convex deployment URL — value from packages/backend/.env.local
VITE_CONVEX_URL=https://bold-raccoon-845.convex.cloud

# Streaming infra. For local dev keep as localhost; for prod swap to your
# Hetzner box (e.g. RTMP_HOST=rtmp://5.6.7.8:1935,
# HLS_HOST=https://stream.yourdomain.com).
# Local-only testing (Mac browser):
#   VITE_HLS_HOST=http://localhost:3000/hls
#   VITE_WEB_HOST=http://localhost:3000
# Phone testing via ngrok (replace with your tunnel URL):
#   VITE_HLS_HOST=https://<your>.ngrok-free.dev/hls
#   VITE_WEB_HOST=https://<your>.ngrok-free.dev
# Production (Hetzner):
#   VITE_HLS_HOST=https://stream.yourdomain.com
#   VITE_WEB_HOST=https://app.yourdomain.com
VITE_RTMP_HOST=rtmp://localhost:1935
VITE_HLS_HOST=http://localhost:3000/hls
VITE_WEB_HOST=http://localhost:3000
